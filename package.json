{
  "name": "ckeditor5-root",
  "private": true,
  "version": "48.3.1",
  "description": "The development environment of CKEditor 5 - the best browser-based rich text editor.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "CKSource (http://cksource.com/)",
  "homepage": "https://ckeditor.com/ckeditor-5",
  "bugs": "https://github.com/ckeditor/ckeditor5/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/ckeditor/ckeditor5.git"
  },
  "engines": {
    "node": ">=24.11.0",
    "pnpm": "^11.8.0",
    "yarn": "\n\n┌─────────────────────────┐\n│  Hey, we use pnpm now!  │\n└─────────────────────────┘\n\n"
  },
  "keywords": [
    "ckeditor",
    "ckeditor5",
    "ckeditor 5",
    "wysiwyg",
    "rich text",
    "editor",
    "html",
    "contentEditable",
    "editing",
    "operational transformation",
    "ot",
    "collaboration",
    "collaborative",
    "real-time",
    "framework"
  ],
  "devDependencies": {
    "@babel/parser": "^7.23.3",
    "@ckbox/uploader": "2.13.0",
    "@ckeditor/ckeditor5-dev-build-tools": "^57.3.0",
    "@ckeditor/ckeditor5-dev-bump-year": "^57.3.0",
    "@ckeditor/ckeditor5-dev-changelog": "^57.3.0",
    "@ckeditor/ckeditor5-dev-ci": "^57.3.0",
    "@ckeditor/ckeditor5-dev-dependency-checker": "^57.3.0",
    "@ckeditor/ckeditor5-dev-docs": "^57.3.0",
    "@ckeditor/ckeditor5-dev-license-checker": "^57.3.0",
    "@ckeditor/ckeditor5-dev-manual-server": "^57.3.0",
    "@ckeditor/ckeditor5-dev-release-tools": "^57.3.0",
    "@ckeditor/ckeditor5-dev-web-crawler": "^57.3.0",
    "@ckeditor/ckeditor5-inspector": "^5.0.1",
    "@ckeditor/ckeditor5-mermaid": "ckeditor/ckeditor5-mermaid#v0.0.7",
    "@ckeditor/ckeditor5-react": "^9.5.0",
    "@inquirer/prompts": "^7.5.0",
    "@listr2/prompt-adapter-inquirer": "^2.0.16",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@webspellchecker/wproofreader-ckeditor5": "^3.0.0",
    "@wiris/mathtype-ckeditor5": "^8.13.1",
    "acorn": "^8.11.3",
    "assert": "^2.0.0",
    "chalk": "^5.0.0",
    "ckbox": "2.13.0",
    "date-fns": "^4.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.34.0",
    "eslint-config-ckeditor5": "^17.1.0",
    "eslint-formatter-stylish": "^8.40.0",
    "eslint-plugin-ckeditor5-rules": "^17.1.0",
    "estree-walker": "^3.0.3",
    "fs-extra": "^11.0.0",
    "glob": "^13.0.0",
    "globals": "^16.1.0",
    "js-beautify": "^1.15.4",
    "js-yaml": "^4.1.1",
    "listr2": "^8.0.0",
    "local-web-server": "^5.4.0",
    "minimist": "^1.2.8",
    "oxc-parser": "^0.72.3",
    "publint": "^0.3.4",
    "puppeteer": "^24.43.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^6.0.1",
    "schema-utils": "^4.2.0",
    "sharp": "^0.34.2",
    "svgo": "^3.3.2",
    "table": "^6.8.1",
    "typescript": "5.5.4",
    "umberto": "^10.7.2",
    "upath": "^2.0.0",
    "vite": "^8.1.3",
    "vitest": "catalog:"
  },
  "scripts": {
    "typecheck": "tsc --emitDeclarationOnly --declarationDir ./build/tmp/types",
    "nice": "ckeditor5-dev-changelog-create-entry",
    "lint": "eslint --format ./scripts/eslint-formatter.cjs --concurrency=4",
    "test": "node scripts/test.mjs",
    "manual": "vite --config ./vite.manual.mts",
    "manual:build": "vite --config ./vite.manual.mts build",
    "manual:preview": "vite --config ./vite.manual.mts preview",
    "manual:verify": "node scripts/check-manual-tests.mjs",
    "reinstall": "pnpx rimraf --glob \"**/node_modules\" && pnpm install",
    "docs": "node scripts/docs/build-docs.mjs",
    "docs:api": "node scripts/docs/workers/build-api-docs.mjs",
    "docs:ckeditor5": "node scripts/docs/workers/build-core.mjs",
    "docs:ckeditor5-premium-features": "node scripts/docs/workers/build-commercial.mjs",
    "docs:serve": "ws --directory ./build/docs/ --compress --https --port 8080",
    "docs:verify": "node ./scripts/web-crawler/index.mjs --docs",
    "build": "node scripts/nim/build-ckeditor5.mjs",
    "release:prepare-changelog": "node ./scripts/release/preparechangelog.mjs",
    "release:prepare-packages": "node ./scripts/release/preparepackages.mjs",
    "release:publish-packages": "node ./scripts/release/publishpackages.mjs",
    "release:deploy-cdn": "node ./scripts/release/deploycdn.mjs",
    "release:lint-packages": "node ./scripts/release/validatepackages.mjs",
    "release:switch-latest-npm": "node ./scripts/release/switchlatestnpm.mjs",
    "release:clean": "node ./scripts/release/clean.mjs",
    "clean-up-svg-icons": "node ./scripts/clean-up-svg-icons.mjs",
    "collect-svg-icons": "node scripts/collect-svg-icons.mjs",
    "check-dependencies": "ckeditor5-dev-dependency-checker",
    "check-dependencies:versions-match": "node ./scripts/ci/check-dependencies-versions-match.mjs",
    "check-exports": "node ./scripts/check-exports.mjs --input=ckeditor5",
    "check-css-imports": "node ./scripts/check-css-imports.mjs",
    "validate-module-re-exports": "node ./scripts/ci/validate-module-re-exports.mjs",
    "bump-year": "node ./scripts/bump-year.mjs",
    "test:scripts": "vitest --config ./scripts-tests/vitest.config.mjs --run",
    "test:memory": "node ./scripts/memory/test-memory.mjs",
    "validate-license-files": "node ./scripts/ci/validate-license-files.mjs"
  },
  "ck-lts-versions": [
    47
  ]
}
