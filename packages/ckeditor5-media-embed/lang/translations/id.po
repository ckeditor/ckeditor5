msgid ""
msgstr ""
"Language: id\n"
"Plural-Forms: nplurals=1; plural=0;\n"
"Content-Type: text/plain; charset=UTF-8\n"

msgctxt "Label for the media widget."
msgid "media widget"
msgstr "widget media"

msgctxt "Label for the URL input in the Media Embed URL editing balloon."
msgid "Media URL"
msgstr "URL Media"

msgctxt "The help text displayed under the media URL input helping users to discover the interface."
msgid "Paste the media URL in the input."
msgstr "Tempelkan URL ke dalam bidang masukan."

msgctxt "The tip displayed next to the media URL input informing about an easier way of embedding."
msgid "Tip: Paste the URL into the content to embed faster."
msgstr "Tip: Tempelkan URL ke bagian konten untuk sisip cepat."

msgctxt "An error message that informs about an empty value in the URL input."
msgid "The URL must not be empty."
msgstr "URL tidak boleh kosong."

msgctxt "An error message that informs about unsupported media URL."
msgid "This media URL is not supported."
msgstr "URL media ini tidak didukung."

msgctxt "Toolbar button tooltip for the Media Embed feature."
msgid "Insert media"
msgstr "Sisipkan media"

msgctxt "Label describing type of the inserted content (e.g. 'insert media')."
msgid "Media"
msgstr "Media"

msgctxt "The label used by assistive technologies describing an image toolbar attached to an image widget."
msgid "Media toolbar"
msgstr "Alat media"

msgctxt "A tooltip displayed when the user hovers a non-previewable media URL in the editor content."
msgid "Open media in new tab"
msgstr "Buka media di tab baru"

msgctxt "The label for the Media Embed balloon."
msgid "Media embed"
msgstr "Sematkan media"

msgctxt "The label for the left aligned media option."
msgid "Left aligned media"
msgstr "Media rata kiri"

msgctxt "The label for the centered media option."
msgid "Centered media"
msgstr "Media tengah"

msgctxt "The label for the right aligned media option."
msgid "Right aligned media"
msgstr "Media rata kanan"

msgctxt "The label used for the dropdown in the media toolbar containing defined resize options."
msgid "Resize media"
msgstr "Ubah ukuran media"

msgctxt "The label used for the standalone resize options buttons in the media toolbar."
msgid "Resize media to %0"
msgstr "Ubah ukuran media menjadi %0"

msgctxt "The accessibility label of the standalone media resize reset option button in the media toolbar for screen readers."
msgid "Resize media to the original size"
msgstr "Kembalikan ukuran media ke ukuran asli"

msgctxt "The label for media resize balloon input."
msgid "Resize media (in %0)"
msgstr "Ubah ukuran media (dalam %0)"

msgctxt "The accessibility label of the standalone media resize custom option button in the media toolbar for screen readers."
msgid "Custom media size"
msgstr "Ukuran media kustom"

msgctxt "The accessibility label of the media resize dropdown for screen readers."
msgid "Media resize list"
msgstr "Daftar ukuran media"

msgctxt "The label for the header of the media resize balloon."
msgid "Media Resize"
msgstr "Ubah Ukuran Media"
