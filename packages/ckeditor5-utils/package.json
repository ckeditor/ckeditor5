{
  "name": "@ckeditor/ckeditor5-utils",
  "version": "48.3.1",
  "description": "Miscellaneous utilities used by CKEditor 5.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "CKSource (http://cksource.com/)",
  "homepage": "https://ckeditor.com/ckeditor-5",
  "bugs": "https://github.com/ckeditor/ckeditor5/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/ckeditor/ckeditor5.git",
    "directory": "packages/ckeditor5-utils"
  },
  "keywords": [
    "ckeditor",
    "ckeditor5",
    "ckeditor 5",
    "ckeditor5-lib"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./dist/*": "./src/*",
    "./*": "./*"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": "./dist/index.js",
      "./dist/*": "./dist/*",
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@ckeditor/ckeditor5-ui": "workspace:*",
    "es-toolkit": "1.45.1"
  },
  "devDependencies": {
    "@ckeditor/ckeditor5-editor-classic": "workspace:*",
    "@ckeditor/ckeditor5-core": "workspace:*",
    "@ckeditor/ckeditor5-engine": "workspace:*",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "build": "node ../../scripts/nim/build-package.mjs",
    "test": "vitest run",
    "test:headless": "vitest run --browser.headless",
    "test:debug": "vitest --watch",
    "coverage": "pnpm run test:headless --coverage"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ]
}
